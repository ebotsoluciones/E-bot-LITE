# ── Identidad ─────────────────────────────────────────────────────────────────
NOMBRE_CONSULTORIO=Consultorio Ejemplo
NOMBRE_PROFESIONAL=Dr. Juan Pérez

# ── Modo ──────────────────────────────────────────────────────────────────────
# false = producción (solo ADMINS entran al panel)
# true  = test (cualquiera escribe "adm" para entrar)
MODO_TEST=false

# ── Admins ────────────────────────────────────────────────────────────────────
ADMINS=whatsapp:+5491100000000

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Notificaciones admin (opcional) ──────────────────────────────────────────
# Si está vacío usa ADMINS[0]
NOTIF_ADMIN_TEL=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=postgres
# DATABASE_URL lo inyecta Railway automáticamente al agregar el plugin PostgreSQL

# ── Horarios ──────────────────────────────────────────────────────────────────
HORA_INICIO=09:00
HORA_FIN=19:00
INTERVALO_MIN=60
